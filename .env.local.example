# ─── Supabase ─────────────────────────────────────────────────────────────────
# Supabase プロジェクトダッシュボード → Settings → API から取得
# https://supabase.com/dashboard

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── 設定手順 ──────────────────────────────────────────────────────────────────
# 1. このファイルを .env.local にコピー
# 2. 上の値を実際のプロジェクト情報に書き換える
# 3. npm install @supabase/supabase-js
# 4. src/lib/supabase.ts のコメントアウトを解除する
# 5. src/lib/submissions.ts を Supabase 版に切り替える
#
# Supabase Storage バケット作成:
#   ダッシュボード → Storage → New Bucket → "practice-videos" (Public)
#
# Supabase DB テーブル作成 (SQL Editor):
#   create table submissions (
#     id uuid primary key,
#     date text not null,
#     song_name text not null,
#     duration int not null,
#     rating int not null,
#     video_url text,
#     video_storage_path text,
#     teacher_comment text,
#     teacher_comment_at bigint,
#     submitted_at bigint not null
#   );
#   alter table submissions enable row level security;
#   create policy "Public read/write" on submissions for all using (true);
